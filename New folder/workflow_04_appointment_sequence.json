              "id": "wf4-f-010",
              "name": "service_type_label",
              "value": "={{ $json.service_type === 'mold' ? 'Mold Inspection' : $json.service_type === 'air_quality' ? 'Air Quality Testing' : $json.service_type === 'emf' ? 'EMF Testing' : $json.service_type === 'chemical' ? 'Chemical/VOC Testing' : 'Multi-Service Inspection' }}",
              "type": "string"
            },
            {
              "id": "wf4-f-011",
              "name": "appointment_datetime_iso",
              "value": "={{ $json.appointment_date + 'T' + $json.appointment_time + ':00' }}",
