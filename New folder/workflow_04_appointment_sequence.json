        },
        "options": {}
      },
      "id": "wf4-0003-aaaa-bbbb-cccc-000000000003",
      "name": "Set - Prepare Booking Variables",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [740, 400]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.customer_email }}",
        "subject": "=Your {{ $json.service_type_label }} is confirmed — Indoor Environmental Testing",
        "emailType": "html",
        "message": "<p>Hi {{ $json.customer_name }},</p>\n\n<p>Great news — your appointment is confirmed! Here are the details:</p>\n\n<table style=\"border-collapse: collapse; width: 100%; max-width: 500px; margin: 20px 0;\">\n  <tr style=\"background: #2E7D32; color: white;\">\n    <td colspan=\"2\" style=\"padding: 12px 16px; font-size: 16px; font-weight: bold;\">Appointment Confirmation</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 16px; font-weight: bold; border: 1px solid #ddd; background: #f9f9f9;\">Service</td>\n    <td style=\"padding: 10px 16px; border: 1px solid #ddd;\">{{ $json.service_type_label }}</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 16px; font-weight: bold; border: 1px solid #ddd; background: #f9f9f9;\">Date</td>\n    <td style=\"padding: 10px 16px; border: 1px solid #ddd;\">{{ $json.appointment_date }}</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 16px; font-weight: bold; border: 1px solid #ddd; background: #f9f9f9;\">Time</td>\n    <td style=\"padding: 10px 16px; border: 1px solid #ddd;\">{{ $json.appointment_time }}</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 16px; font-weight: bold; border: 1px solid #ddd; background: #f9f9f9;\">Inspector</td>\n    <td style=\"padding: 10px 16px; border: 1px solid #ddd;\">{{ $json.inspector_name }}</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 16px; font-weight: bold; border: 1px solid #ddd; background: #f9f9f9;\">Property Address</td>\n    <td style=\"padding: 10px 16px; border: 1px solid #ddd;\">{{ $json.property_address }}</td>\n  </tr>\n</table>\n\n<h3 style=\"color: #2E7D32;\">What to expect:</h3>\n<ul>\n  <li>Your inspector will arrive within a 30-minute window of your scheduled time</li>\n  <li>The inspection typically takes 1–3 hours depending on the property size and services</li>\n  <li>You'll receive a detailed written report within 2–3 business days</li>\n  <li>We'll walk you through preliminary findings before we leave</li>\n</ul>\n\n<p>You'll receive a preparation email 48 hours before your appointment with specific instructions to ensure the most accurate results.</p>\n\n<p>If you need to reschedule or have any questions, please don't hesitate to contact us:</p>\n<ul>\n  <li>Email: <a href=\"mailto:martine@indoorenvironmentaltesting.com\">martine@indoorenvironmentaltesting.com</a></li>\n  <li>Phone: YOUR_PHONE_NUMBER</li>\n  <li>Online: <a href=\"YOUR_APPTOTAL_BOOKING_LINK\">Reschedule Online</a></li>\n</ul>\n\n<p>We look forward to seeing you on {{ $json.appointment_date }}!</p>\n\n<p>Warm regards,<br>\n<strong>Martine Davis &amp; the IET Team</strong><br>\nIndoor Environmental Testing Inc.<br>\nMadison, WI | Nashville, TN</p>",
        "options": {
          "replyTo": "martine@indoorenvironmentaltesting.com"
        }
      },
