              "name": "appointment_date",
              "value": "={{ $json.appointment_date }}",
              "type": "string"
            },
            {
              "id": "wf4-f-005",
              "name": "appointment_time",
              "value": "={{ $json.appointment_time }}",
              "type": "string"
            },
            {
              "id": "wf4-f-006",
              "name": "service_type",
              "value": "={{ $json.service_type }}",
              "type": "string"
            },
            {
              "id": "wf4-f-007",
              "name": "inspector_name",
              "value": "={{ $json.inspector_name }}",
              "type": "string"
            },
            {
              "id": "wf4-f-008",
              "name": "property_address",
              "value": "={{ $json.property_address }}",
              "type": "string"
